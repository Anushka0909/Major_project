# ============================================================
# TRADE FLOW PREDICTION PROJECT - .gitignore
# ============================================================

# Environments
.env
.venv/
env/
venv/
node_modules/

# Python Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.pytest_cache/

# IDE & Editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# OS Files
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db

# Project Logs (Allowing dir but ignoring log files is common, but user wants everything)
# logs/*.log

# ALLOW EVERYTHING ELSE (Data, Models, etc. as requested)
!data/
!models/
!logs/
!src/
!configs/
!scripts/

# Except local secrets
.env.local
.env.*.local
secrets/
credentials/*.key
credentials/*.pem
